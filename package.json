{
	"name": "webext-patterns",
	"version": "1.5.1",
	"description": "Tool to convert the patterns and globs of your WebExtension manifest to regex",
	"keywords": [
		"browser",
		"chrome",
		"extension",
		"firefox",
		"glob",
		"permission",
		"greasemonkey",
		"user scripts",
		"globs",
		"userscript",
		"match",
		"webext"
	],
	"repository": "fregante/webext-patterns",
	"funding": "https://github.com/sponsors/fregante",
	"license": "MIT",
	"author": "Federico Brigante <me@fregante.com> (https://fregante.com)",
	"type": "module",
	"exports": "./index.js",
	"types": "./index.d.ts",
	"files": [
		"index.js",
		"index.d.ts"
	],
	"scripts": {
		"build": "tsc",
		"fix": "xo --fix",
		"lint": "xo",
		"prepare": "tsc --sourceMap false",
		"test": "tsc && ava && xo",
		"watch": "tsc --watch"
	},
	"dependencies": {
		"escape-string-regexp": "^5.0.0"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^8.1.0",
		"@types/chrome": "^0.1.39",
		"ava": "^7.0.0",
		"globals": "^17.4.0",
		"sinon": "^21.0.3",
		"type-fest": "^5.5.0",
		"typescript": "^6.0.2",
		"xo": "^2.0.2"
	},
	"engines": {
		"node": ">=18"
	},
	"webExt": {
		"sourceDir": "demo-extension",
		"run": {
			"startUrl": [
				"chrome://extensions/",
				"https://example.com/"
			]
		}
	}
}
